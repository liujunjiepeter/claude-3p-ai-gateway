# ============================================
# AI Gateway 配置
# 复制为 .env 并填入你的 API Key
# ============================================

# One-API 管理员初始密码（首次启动使用，登录后建议修改）
ONEAPI_INIT_PASSWORD=123456

# 💡 模型名映射：客户端发 claude-xxx 自动映射到真实模型名
# 键名必须是 Claude 白名单中的模型名（如 claude-3-5-sonnet-20241022）
MODEL_MAPPING={"claude-3-5-sonnet-20241022":"deepseek-v4-pro","claude-3-5-haiku-20241022":"mimo-v2.5"}

# 代理暴露给客户端的模型列表（必须是白名单名）
MODELS=[{"id":"claude-3-5-sonnet-20241022","type":"model","display_name":"DeepSeek V4 Pro"},{"id":"claude-3-5-haiku-20241022","type":"model","display_name":"MiMo V2.5"}]

# ---------- 渠道 1: DeepSeek ----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-pro

# ---------- 渠道 2: 小米 MiMo ----------
XIAOMI_API_KEY=tp-your-xiaomi-key
XIAOMI_MODEL=mimo-v2.5
XIAOMI_BASE_URL=https://token-plan-cn.xiaomimimo.com

# ---------- One-API 令牌（setup.sh 自动生成后回填） ----------
ONEAPI_TOKEN=
