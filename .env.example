# ============================================
# AI Gateway 配置
# 复制为 .env 并填入你的 API Key
# ============================================

# One-API 管理员初始密码（首次启动使用，登录后建议修改）
ONEAPI_INIT_PASSWORD=123456

# 代理暴露的模型列表（JSON 数组，需与 One-API 渠道中配置的模型名一致）
# 支持任意 OpenAI 兼容模型：GPT-4o、Claude Sonnet、Gemini、Qwen 等
MODELS=[{"id":"deepseek-v4-pro","type":"model","display_name":"DeepSeek V4 Pro"},{"id":"mimo-v2.5","type":"model","display_name":"MiMo V2.5"}]

# ---------- 渠道 1: DeepSeek ----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-pro

# ---------- 渠道 2: 小米 MiMo ----------
XIAOMI_API_KEY=tp-your-xiaomi-key
XIAOMI_MODEL=mimo-v2.5
XIAOMI_BASE_URL=https://token-plan-cn.xiaomimimo.com

# ---------- One-API 令牌（setup.sh 自动生成后回填） ----------
ONEAPI_TOKEN=
